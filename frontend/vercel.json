{
    "buildCommand": "npm run vercel-build",
    "outputDirectory": "dist/frontend/browser",
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://world-simulation-af8k.onrender.com/api/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}